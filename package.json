{
  "name": "grokforge",
  "displayName": "GrokForge",
  "description": "Grok-native VS Code chat with multi-agent orchestration via xAI Responses API",
  "version": "0.1.0",
  "publisher": "grokforge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "grokforge",
          "title": "GrokForge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "grokforge": [
        {
          "type": "webview",
          "id": "grokforge.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "grokforge.setApiKey",
        "title": "GrokForge: Set xAI API Key"
      },
      {
        "command": "grokforge.newChat",
        "title": "GrokForge: New Chat"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package",
    "lint": "eslint src --ext ts,vue"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "esbuild-plugin-vue3": "^0.4.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@ai-sdk/xai": "^1.0.0",
    "@types/dompurify": "^3.0.5",
    "ai": "^4.0.0",
    "dompurify": "^3.3.3",
    "marked": "^12.0.0",
    "vue": "^3.4.0"
  }
}
